{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/signin",
      "methods": ["POST"],
      "dest": "/api/auth/signin.js"
    },
    {
      "src": "/api/auth/signup", 
      "methods": ["POST"],
      "dest": "/api/auth/signup.js"
    },
    {
      "src": "/api/feed",
      "methods": ["GET", "POST"],
      "dest": "/api/feed/index.js"
    },
    {
      "src": "/api/credits",
      "methods": ["GET", "POST"],
      "dest": "/api/credits.js"
    }
  ]
}