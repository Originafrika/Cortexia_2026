# ============================================
# CORTEXIA ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - add .env to .gitignore!

# ============================================
# SERVER-SIDE ONLY (NOT exposed to browser)
# ============================================

# Database (Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# Bcrypt rounds (default: 12)
BCRYPT_ROUNDS=12

# ============================================
# STRIPE (Enterprise)
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_1000=price_xxxxxxxxxxxxxxx
STRITE_PRICE_CREDITS_5000=price_xxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_10000=price_xxxxxxxxxxxxxxx

# ============================================
# FEDAPAY (Individual Africa - Mobile Money)
# ============================================
FEDAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
FEDAPAY_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# CLOUDFLARE AI (Free tier)
# ============================================
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# ============================================
# UPSTASH (Rate Limiting & QStash)
# ============================================
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
QSTASH_URL=https://qstash.upstash.io/v1/
QSTASH_TOKEN=your-qstash-token

# ============================================
# R2 STORAGE (Outputs)
# ============================================
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cortexia
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ============================================
# FRONTEND (VITE - exposed to browser)
# ============================================

# Cloudflare Account ID (public - exposed au navigateur)
VITE_CF_ACCOUNT_ID=your-cf-account-id

# Cloudflare API Token (SECRET - NE PAS exposer avec VITE_, mettre seulement CF_API_TOKEN)

# Upstash Redis
VITE_UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
VITE_UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Groq (LLM fallback)
VITE_GROQ_API_KEY=your-groq-api-key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Neon Auth
VITE_NEON_AUTH_URL=https://your-project.auth.neon.tech

# R2 Storage
VITE_R2_ACCOUNT_ID=your-r2-account-id
VITE_R2_BUCKET_NAME=cortexia
VITE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API URL
VITE_API_URL=http://localhost:3001

# Sentry
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=

# App
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ============================================
# ALLOWED ORIGINS (for CORS)
# ============================================
ALLOWED_ORIGINS=https://cortexia.app,https://cortexia.vercel.app

# ============================================
# NODE ENV
# ============================================
NODE_ENV=development